<h2>Keyframes</h2>
<p>
    Animate a property through a <em>sequence</em> of values by passing arrays in
    <code>AnimationProps.Keyframes</code>. Keys match property names (camelCase).
    Use <code>TransitionConfig.Times</code> for custom timing offsets (0–1).
</p>
<pre><code>&lt;Motion Animate="@@(new AnimationProps
        {
            Keyframes = new Dictionary&lt;string, object&gt;
            {
                ["x"]               = new double[] { 0, 100, 50, 80, 0 },
                ["backgroundColor"] = new string[] { "#6c47ff", "#ff4785", "#eab308", "#6c47ff" }
            }
        })"
        Transition="@@(new TransitionConfig
        {
            Type     = TransitionType.Keyframes,
            Times    = new[] { 0.0, 0.3, 0.6, 0.8, 1.0 },
            Duration = 2.0,
            Repeat   = int.MaxValue
        })" /&gt;</code></pre>

<div class="demo-area" style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion Class="demo-box"
                Animate="@(new AnimationProps
                {
                    Keyframes = new Dictionary<string, object>
                    {
                        ["scale"] = new double[] { 1.0, 1.35, 0.85, 1.1, 1.0 }
                    }
                })"
                Transition="@(new TransitionConfig
                {
                    Type       = TransitionType.Keyframes,
                    Duration   = 1.0,
                    Repeat     = int.MaxValue,
                    RepeatType = RepeatType.Loop
                })">
            Pulse
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">scale keyframes</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion Class="demo-box"
                Animate="@(new AnimationProps
                {
                    Keyframes = new Dictionary<string, object>
