            BG Color
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">BackgroundColor</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion @key="_replayKey4"
                Class="demo-box"
                Style="border: 3px solid #6c47ff;"
                Initial="@(new AnimationProps { BorderColor = "#6c47ff", Scale = 1 })"
                Animate="@(new AnimationProps  { BorderColor = "#22c55e", Scale = 1.1 })"
