<h2>Repeating animations</h2>
<p>
    Use <code>Repeat</code> and <code>RepeatType</code> on <code>TransitionConfig</code> to loop,
    mirror, or reverse an animation.
</p>
<pre><code>// Infinite loop
new TransitionConfig { Repeat = int.MaxValue, RepeatType = RepeatType.Loop }

// Ping-pong (reverse each cycle)
new TransitionConfig { Repeat = int.MaxValue, RepeatType = RepeatType.Mirror }

// Pause between repeats
new TransitionConfig { Repeat = 5, RepeatDelay = 0.5 }</code></pre>

<div class="demo-area" style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion Class="demo-box"
                Initial="@(new AnimationProps { X = -40 })"
                Animate="@(new AnimationProps  { X = 40 })"
                Transition="@(new TransitionConfig
                {
                    Duration   = 0.6,
                    Ease       = Easing.EaseInOut,
                    Repeat     = int.MaxValue,
                    RepeatType = RepeatType.Mirror
                })">
            Mirror
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">RepeatType.Mirror</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion Class="demo-box"
                Initial="@(new AnimationProps { Rotate = 0 })"
                Animate="@(new AnimationProps  { Rotate = 360 })"
                Transition="@(new TransitionConfig
                {
                    Duration   = 1.5,
                    Ease       = Easing.Linear,
                    Repeat     = int.MaxValue,
                    RepeatType = RepeatType.Loop
                })">
            Spin
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">Rotate loop</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion Class="demo-box"
                Initial="@(new AnimationProps { Opacity = 1 })"
                Animate="@(new AnimationProps  { Opacity = 0.15 })"
                Transition="@(new TransitionConfig
                {
                    Duration   = 0.9,
                    Ease       = Easing.EaseInOut,
                    Repeat     = int.MaxValue,
                    RepeatType = RepeatType.Mirror
                })">
            Breathe
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">Opacity mirror</span>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Reactive (state-driven) animations</h2>
<p>
    Bind <code>Animate</code> to a C# property that derives from component state.
    Every time the state changes, BlazorMotion smoothly transitions to the new target.
</p>
<pre><code>@@code {
    bool _expanded = false;
    AnimationProps _boxStyle =&gt; _expanded
        ? new AnimationProps { Width = "240px", Height = "240px", BorderRadius = "24px" }
        : new AnimationProps { Width = "80px",  Height = "80px",  BorderRadius = "50%" };
}

&lt;Motion Style="background:#6c47ff;cursor:pointer;"
        Animate="@@_boxStyle"
        Transition="@@(new TransitionConfig { Type = TransitionType.Spring, Stiffness = 300, Damping = 25 })"
        @@onclick="@@(() =&gt; _expanded = !_expanded)" /&gt;</code></pre>

<div class="demo-area" style="display:flex;flex-direction:column;align-items:center;gap:1rem;">
    <p style="font-size:0.85rem;color:var(--text-muted)">Click the shape to toggle</p>
    <Motion Style="background:#6c47ff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;"
            Animate="@_reactiveStyle"
            Transition="@(new TransitionConfig { Type = TransitionType.Spring, Stiffness = 300, Damping = 25 })"
            @onclick="ToggleExpanded">
        @(_expanded ? "Collapse" : "Expand")
    </Motion>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Per-property transitions</h2>
<p>
    Override the transition for individual properties using <code>TransitionConfig.Properties</code>.
    This is useful when different values need different timing — for example opacity should fade
    quickly while a spring drives the movement.
</p>
<pre><code>&lt;Motion Initial="@@(new AnimationProps { Opacity = 0, Y = 40 })"
        Animate="@@(new AnimationProps  { Opacity = 1, Y = 0 })"
        Transition="@@(new TransitionConfig
        {
            Type = TransitionType.Spring,
            Stiffness = 200, Damping = 20,
            Properties = new Dictionary&lt;string, TransitionConfig&gt;
            {
                ["opacity"] = new TransitionConfig
                {
                    Type     = TransitionType.Tween,
                    Duration = 0.15,
                    Ease     = Easing.Linear
                }
            }
        })" /&gt;</code></pre>

<div class="demo-area" style="display:flex;flex-direction:column;align-items:center;gap:1.25rem;">
    <Motion @key="_replayKey5"
            Class="demo-box"
            Initial="@(new AnimationProps { Opacity = 0, Y = 50 })"
            Animate="@(new AnimationProps  { Opacity = 1, Y = 0 })"
            Transition="@(new TransitionConfig
            {
                Type = TransitionType.Spring,
                Stiffness = 180, Damping = 14,
                Properties = new Dictionary<string, TransitionConfig>
                {
                    ["opacity"] = new TransitionConfig
                    {
                        Type     = TransitionType.Tween,
                        Duration = 0.15,
                        Ease     = Easing.Linear
                    }
                }
            })">
        Fast fade, spring slide
    </Motion>
    <button class="demo-button" @onclick="Replay5">&#9654; Replay</button>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Delay</h2>
<p>
    Use <code>Delay</code> on <code>TransitionConfig</code> to postpone the start of an animation.
    Useful for sequencing items without variants.
</p>
<pre><code>@@foreach (var (item, i) in items.Select((v, i) =&gt; (v, i)))
{
    &lt;Motion Initial="@@(new AnimationProps { Opacity = 0, X = -20 })"
            Animate="@@(new AnimationProps  { Opacity = 1, X = 0 })"
            Transition="@@(new TransitionConfig { Duration = 0.4, Delay = i * 0.1 })"&gt;
        @@item
    &lt;/Motion&gt;
}</code></pre>

<div class="demo-area" style="display:flex;flex-direction:column;gap:0.6rem;align-items:flex-start;padding-left:2rem;">
    @foreach (var (label, i) in _listItems.Select((l, i) => (l, i)))
    {
        <Motion @key="@($"li{_replayKey6}-{i}")"
                Style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:0.5rem 1.2rem;font-weight:500;"
                Initial="@(new AnimationProps { Opacity = 0, X = -30 })"
                Animate="@(new AnimationProps  { Opacity = 1, X = 0 })"
                Transition="@(new TransitionConfig { Duration = 0.4, Ease = Easing.EaseOut, Delay = i * 0.08 })">
            @label
        </Motion>
    }
    <button class="demo-button" @onclick="Replay6">&#9654; Replay</button>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>CSS custom properties</h2>
<p>
    Animate CSS custom properties (variables) using the <code>CssVars</code> dictionary.
    Keys must start with <code>--</code>. The element and any descendants that reference the
    variable will update automatically.
</p>
<pre><code>&lt;Motion Animate="@@(new AnimationProps
        {
            CssVars = new Dictionary&lt;string, string&gt;
            {
                ["--hue"] = "260"
            }
        })"
        Transition="@@(new TransitionConfig { Duration = 2, Repeat = int.MaxValue, RepeatType = RepeatType.Mirror })"
        Style="background: hsl(var(--hue), 70%, 55%)" /&gt;</code></pre>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>SVG path drawing</h2>
<p>
    Animate SVG strokes being "drawn" using <code>PathLength</code>, <code>PathOffset</code>, and
    <code>PathSpacing</code>. Values are normalised 0–1 relative to the path's total length.
</p>
<pre><code>&lt;svg viewBox="0 0 200 200"&gt;
    &lt;Motion Tag="path"
            d="M10 100 Q100 20 190 100"
            stroke="#6c47ff" stroke-width="4" fill="none"
            Initial="@@(new AnimationProps { PathLength = 0 })"
            Animate="@@(new AnimationProps  { PathLength = 1 })"
            Transition="@@(new TransitionConfig { Duration = 1.5, Ease = Easing.EaseInOut })" /&gt;
&lt;/svg&gt;</code></pre>

<div class="demo-area" style="display:flex;flex-direction:column;align-items:center;gap:1rem;">
    <svg viewBox="0 0 220 120" style="width:220px;height:120px;overflow:visible;">
        <Motion @key="_replayKey7"
                Tag="path"
                d="M10 60 C60 10, 160 10, 210 60"
                stroke="#6c47ff" stroke-width="4" fill="none" stroke-linecap="round"
                Initial="@(new AnimationProps { PathLength = 0 })"
                Animate="@(new AnimationProps  { PathLength = 1 })"
                Transition="@(new TransitionConfig { Duration = 1.4, Ease = Easing.EaseInOut })" />
    </svg>
    <button class="demo-button" @onclick="Replay7">&#9654; Replay</button>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Animation events</h2>
<p>BlazorMotion fires <code>EventCallback</code>s at key points in the animation lifecycle:</p>
<pre><code>&lt;Motion Initial="@@(new AnimationProps { Opacity = 0 })"
        Animate="@@(new AnimationProps  { Opacity = 1 })"
        OnAnimationStart="@@HandleStart"
        OnAnimationComplete="@@HandleComplete"&gt;
    ...
&lt;/Motion&gt;

@@code {
    void HandleStart()    =&gt; Console.WriteLine("animation started");
    void HandleComplete() =&gt; Console.WriteLine("animation done");
}</code></pre>

<table class="prop-table">
    <thead><tr><th>Event</th><th>Description</th></tr></thead>
    <tbody>
        <tr><td>OnAnimationStart</td><td>Fires when a new animation begins (including re-triggers).</td></tr>
        <tr><td>OnAnimationComplete</td><td>Fires when the animation reaches its target (not fired for infinite repeats).</td></tr>
    </tbody>
</table>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Exit animations</h2>
<p>
    Wrap conditional elements in <code>&lt;AnimatePresence&gt;</code> and add an <code>Exit</code>
    prop to animate elements as they are removed from the DOM.
</p>
<pre><code>&lt;AnimatePresence&gt;
    @@if (show)
    {
        &lt;Motion Initial="@@(new AnimationProps { Opacity = 0, Y = -20 })"
                Animate="@@(new AnimationProps  { Opacity = 1, Y = 0 })"
                Exit="@@(new AnimationProps     { Opacity = 0, Y = 20 })"
                Transition="@@(new TransitionConfig { Duration = 0.3 })"&gt;
            I animate in and out
        &lt;/Motion&gt;
    }
&lt;/AnimatePresence&gt;</code></pre>

<p>See <a href="/docs/animate-presence">AnimatePresence</a> for the full reference.</p>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Variants</h2>
<p>
    Define named animation states in a <code>MotionVariants</code> dictionary and switch between
    them with a string key. Variants can also propagate to children to enable staggered list
    animations.
</p>
<pre><code>@@code {
    readonly MotionVariants _variants = new()
    {
        ["hidden"]  = new AnimationProps { Opacity = 0, Y = 20 },
        ["visible"] = new AnimationProps { Opacity = 1, Y = 0  }
    };
    string _state = "hidden";
}

&lt;Motion Variants="@@_variants"
        VariantKey="@@_state"
        Transition="@@(new TransitionConfig { Type = TransitionType.Spring })"&gt;
    @@_state
&lt;/Motion&gt;

&lt;button @@onclick="@@(() =&gt; _state = "visible")"&gt;Show&lt;/button&gt;</code></pre>

<p>See <a href="/docs/variants">Variants</a> for the full reference including stagger and propagation.</p>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>AnimationProps reference</h2>
<table class="prop-table">
    <thead><tr><th>Property</th><th>Type</th><th>Description</th></tr></thead>
    <tbody>
        <tr><td colspan="3" style="font-weight:600;background:var(--bg-nav)">Transforms</td></tr>
        <tr><td>X</td><td>double?</td><td>Translate on X axis (px)</td></tr>
        <tr><td>Y</td><td>double?</td><td>Translate on Y axis (px)</td></tr>
        <tr><td>Z</td><td>double?</td><td>Translate on Z axis (px, requires perspective)</td></tr>
        <tr><td>Scale</td><td>double?</td><td>Uniform scale</td></tr>
        <tr><td>ScaleX</td><td>double?</td><td>Scale on X axis</td></tr>
        <tr><td>ScaleY</td><td>double?</td><td>Scale on Y axis</td></tr>
        <tr><td>Rotate</td><td>double?</td><td>Rotation around Z axis (degrees)</td></tr>
        <tr><td>RotateX</td><td>double?</td><td>3-D rotation around X axis (degrees)</td></tr>
        <tr><td>RotateY</td><td>double?</td><td>3-D rotation around Y axis (degrees)</td></tr>
        <tr><td>RotateZ</td><td>double?</td><td>Alias for Rotate</td></tr>
        <tr><td>SkewX</td><td>double?</td><td>Skew on X axis (degrees)</td></tr>
        <tr><td>SkewY</td><td>double?</td><td>Skew on Y axis (degrees)</td></tr>
