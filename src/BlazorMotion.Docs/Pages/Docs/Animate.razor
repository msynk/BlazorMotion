@page "/docs/animate"

<PageTitle>Animate — BlazorMotion</PageTitle>

<div class="breadcrumb">Docs / <span>Animate</span></div>
<h1>Animate</h1>
<p>
    Animate elements by setting values on the <code>Animate</code> parameter.
    BlazorMotion automatically transitions from <code>Initial</code> to <code>Animate</code>
    on mount and re-animates whenever <code>Animate</code> changes.
    All animation physics run in C# (WASM) — no external JS animation library required.
</p>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Enter animation</h2>
<p>
    Set <code>Initial</code> to define where an element starts, and <code>Animate</code>
    to define where it ends. BlazorMotion plays this animation once on mount.
</p>
<pre><code>&lt;Motion Tag="div"
        Initial="@@(new AnimationProps { Opacity = 0, Y = 30 })"
        Animate="@@(new AnimationProps  { Opacity = 1, Y = 0 })"
        Transition="@@(new TransitionConfig { Duration = 0.5, Ease = Easing.EaseOut })"&gt;
    Hello!
&lt;/Motion&gt;</code></pre>

<div class="demo-area">
    <div style="display:flex;flex-direction:column;align-items:center;gap:1.25rem;">
        <Motion @key="_replayKey"
                Class="demo-box"
                Initial="@(new AnimationProps { Opacity = 0, Y = 30 })"
                Animate="@(new AnimationProps  { Opacity = 1, Y = 0 })"
                Transition="@(new TransitionConfig { Duration = 0.6, Ease = Easing.EaseOut })">
            Fade up
        </Motion>
        <button class="demo-button" @onclick="Replay">&#9654; Replay</button>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<h2>Multiple values</h2>
<p>Animate any combination of transform, opacity, color, and layout properties simultaneously.</p>
<pre><code>&lt;Motion Tag="div"
        Initial="@@(new AnimationProps { Opacity = 0, Scale = 0.5, Y = -20 })"
        Animate="@@(new AnimationProps  { Opacity = 1, Scale = 1,   Y = 0 })"
        Transition="@@(new TransitionConfig { Duration = 0.4, Ease = Easing.EaseOut })" /&gt;</code></pre>

<div class="demo-area" style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion @key="_replayKey2"
                Class="demo-box"
                Initial="@(new AnimationProps { Opacity = 0, Scale = 0.3 })"
                Animate="@(new AnimationProps  { Opacity = 1, Scale = 1 })"
                Transition="@(TransitionConfig.BounceSpring(0.5, 0.4))">
            Scale + Fade
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">Scale + Opacity</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion @key="_replayKey2"
                Class="demo-box"
                Initial="@(new AnimationProps { Opacity = 0, X = -50, Rotate = -15 })"
                Animate="@(new AnimationProps  { Opacity = 1, X = 0,  Rotate = 0 })"
                Transition="@(new TransitionConfig { Type = TransitionType.Spring, Stiffness = 260, Damping = 20 })">
            Rotate + Slide
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">X + Rotate + Opacity</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
        <Motion @key="_replayKey2"
                Class="demo-box"
                Initial="@(new AnimationProps { Opacity = 0, Scale = 1.5, BorderRadius = "50%" })"
                Animate="@(new AnimationProps  { Opacity = 1, Scale = 1,   BorderRadius = "12px" })"
                Transition="@(new TransitionConfig { Duration = 0.55, Ease = Easing.EaseOut })">
            Morph
        </Motion>
        <span style="font-size:0.75rem;color:var(--text-muted)">Scale + BorderRadius</span>
    </div>
    <button class="demo-button" style="align-self:flex-end;" @onclick="Replay2">&#9654; Replay</button>
