<h2>Transforms</h2>
<p>BlazorMotion supports the full set of CSS transform properties as first-class numeric values:</p>

<h3>Translate</h3>
<pre><code>new AnimationProps { X = 100 }    // translate X by 100 px
new AnimationProps { Y = -50 }    // translate Y by -50 px
new AnimationProps { X = 80, Y = 40 }</code></pre>

<h3>Scale</h3>
<pre><code>new AnimationProps { Scale  = 1.5 }          // uniform
new AnimationProps { ScaleX = 2, ScaleY = 0.5 }  // independent axes</code></pre>

<h3>Rotate</h3>
<pre><code>new AnimationProps { Rotate  = 180 }              // Z-axis, degrees
new AnimationProps { RotateX = 45 }               // 3-D tilt
new AnimationProps { RotateY = 45 }
new AnimationProps { RotateZ = 90 }</code></pre>

<h3>Skew</h3>
<pre><code>new AnimationProps { SkewX = 15 }   // degrees
new AnimationProps { SkewY = -10 }</code></pre>

<h3>Perspective</h3>
<pre><code>new AnimationProps { Perspective = 1200 }   // px, parent context depth</code></pre>

<div class="demo-area" style="display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;">
    @foreach (var (label, init, anim) in _transformDemos)
    {
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
            <Motion @key="@($"t{_replayKey3}-{label}")"
                    Class="demo-box"
                    Initial="@init"
                    Animate="@anim"
                    Transition="@(new TransitionConfig { Type = TransitionType.Spring, Stiffness = 200, Damping = 18 })">
                @label
            </Motion>
            <span style="font-size:0.75rem;color:var(--text-muted)">@label</span>
        </div>
    }
    <button class="demo-button" style="align-self:flex-end;" @onclick="Replay3">&#9654; Replay</button>
</div>

