@page "/keyframes"

<div class="demo-section">
    <h2>Keyframes</h2>
    <p>
        Pass an array of values in the <c>Keyframes</c> dictionary of <c>AnimationProps</c>
        to define a multi-step animation. Use <c>Transition.Times</c> for custom offsets (0–1).
    </p>

    <div class="demo-row">
        <div class="demo-card">
            <Motion Tag="div"
                    Class="box"
                    Animate="@(new AnimationProps
                    {
                        Keyframes = new() {
                            ["scale"]  = new double[] { 1, 1.3, 0.8, 1.1, 1 },
                            ["rotate"] = new double[] { 0, 15, -10, 5, 0 }
                        }
                    })"
                    Transition="@(new TransitionConfig
                    {
                        Duration   = 1.2,
                        Ease       = Easing.EaseInOut,
                        Repeat     = int.MaxValue,
                        RepeatType = RepeatType.Mirror
                    })" />
        </div>

        <div class="demo-card">
            <Motion Tag="div"
                    Class="box"
                    Style="height:30px;border-radius:4px;"
                    Animate="@(new AnimationProps
                    {
                        Keyframes = new() {
                            ["x"] = new double[] { 0, 100, 60, 120, 0 }
                        }
                    })"
                    Transition="@(new TransitionConfig
                    {
                        Duration   = 2,
                        Times      = new[] { 0.0, 0.2, 0.5, 0.8, 1.0 },
                        Ease       = Easing.EaseInOut,
                        Repeat     = int.MaxValue
                    })" />
        </div>
    </div>
</div>

<div class="demo-section">
    <h2>Color Keyframes</h2>
    <p>Smoothly cycle through a palette of colors.</p>
    <div class="demo-row">
        <div class="demo-card">
            <Motion Tag="div"
                    Class="box"
                    Style="width:120px;height:120px;border-radius:50%;background-image:none;"
                    Animate="@(new AnimationProps
                    {
                        Keyframes = new() {
                            ["backgroundColor"] = new string[] { "#6c47ff", "#ff4785", "#00c3ff", "#6c47ff" }
                        }
                    })"
                    Transition="@(new TransitionConfig
                    {
                        Duration  = 3,
                        Repeat    = int.MaxValue,
                        Ease      = Easing.Linear
                    })" />
        </div>
    </div>
</div>

